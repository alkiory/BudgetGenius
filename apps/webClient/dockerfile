# 1. Builder
FROM node:20.10.0 AS builder
WORKDIR /app

# Instalación de pnpm
RUN npm install -g pnpm && corepack enable

# Copia de archivos base (desde la raíz del monorepo)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/api/package.json ./apps/api/
COPY apps/webClient/package.json ./apps/webClient/

RUN pnpm install --frozen-lockfile

# Copiamos todo el monorepo
COPY . .

# Variables de entorno para el build (si es necesario)
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

# Limpiamos cualquier build previo (si existe) para evitar conflictos
RUN rm -rf apps/webClient/dist

# Construimos el frontend
RUN pnpm run build --filter frontend-web

# 2. Servidor Nginx
FROM nginx:stable-alpine

# IMPORTANTE: Aquí está el cambio. 
# Si el archivo se llama nginx.conf y está dentro de apps/webClient:
COPY apps/webClient/nginx.conf /etc/nginx/conf.d/default.conf

# Copia del build
COPY --from=builder /app/apps/webClient/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]