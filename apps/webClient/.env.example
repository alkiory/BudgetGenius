VITE_API_URL=http://localhost:5000/api
VITE_FRONTEND_URL=http://localhost:5173

# Test credentials
TEST_USER_EMAIL=test@test.com
TEST_USER_PASSWORD=#Password123

# Firebase
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_GOOGLE_CLIENT_ID=# Web OAuth Client ID for @capgo/capacitor-social-login
# (replaces VITE_GOOGLE_CLIENT_ID's role in the native Google login).
# Must be a *.apps.googleusercontent.com string from Google Cloud
# Console → APIs & Services → Credentials → Web application OAuth
# Client. The Android OAuth Client is registered separately and used
# internally by Credential Manager — it does NOT go in this env var.
VITE_GOOGLE_WEB_CLIENT_ID=

# Android APK download URL (GitHub Releases).
# Fixed-URL strategy (NOT a GitHub-API call): each visitor hits this
# static link, no API rate-limit dependency (60 req/hour anonymous).
# Pattern: https://github.com/{owner}/{repo}/releases/download/v{version}/BudgetGenius-v{version}.apk
#
# When this is empty OR still contains a placeholder token
# (REPLACE_ME / TODO / PLACEHOLDER / YOUR_ORG / YOUR_REPO),
# the download button on the landing page switches to a disabled
# "Coming soon" state, so a partial rollout never points to a 404.
#
# Update procedure on each new APK release:
# 1. Create the Git tag `vX.Y.Z` (annotated) and push it.
# 2. Create the GitHub Release from that tag, attaching
#    the binary as `BudgetGenius-vX.Y.Z.apk` (exact name).
# 3. Update VITE_APK_DOWNLOAD_URL in .env.production (and
#    .env.development if you want the dev server to mirror it),
#    then redeploy the frontend.
VITE_APK_DOWNLOAD_URL=https://github.com/REPLACE_ME/YOUR_REPO/releases/download/v0.0.0/BudgetGenius-v0.0.0.apk
