{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "author": "Alkiory",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=production pnpm build && typeorm-ts-node-commonjs migration:run && node dist/src/main.js",
    "dev": "NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch --preserveWatchOutput",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm migration:generate -d src/data-source.ts src/migrations/InitialMigration",
    "migration:run": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "premigration:run": "node -e \"const { Client } = require('pg'); const client = new Client({ host: process.env.DB_HOST || 'localhost', port: process.env.DB_PORT || 5432, user: process.env.DB_USER || 'postgres', password: process.env.DB_PASSWORD || process.env.DB_PASS || 'postgres', database: process.env.DB_NAME || 'budgetgenius' }); client.connect().then(() => client.query('CREATE SCHEMA IF NOT EXISTS bg_public;')).then(() => client.end()).catch(err => { console.error(err); process.exit(1); })\"",
    "migration:show": "pnpm exec typeorm-ts-node-commonjs migration:show -d src/data-source.ts",
    "migration:create": "pnpm exec typeorm-ts-node-commonjs migration:create",
    "migration:revert": "pnpm typeorm migration:revert -d src/data-source.ts",
    "migration:run:prod": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d dist/src/data-source.js"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "1.1.0",
    "@nestjs/common": "11.0.0",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.0.0",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.0.0",
    "@nestjs/serve-static": "5.0.3",
    "@nestjs/swagger": "11.1.1",
    "@nestjs/throttler": "6.4.0",
    "@nestjs/typeorm": "11.0.0",
    "bcryptjs": "3.0.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "dotenv": "17.4.2",
    "ioredis": "5.5.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "openai": "4.86.2",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "4.0.1",
    "pg": "8.13.3",
    "reflect-metadata": "0.1.14",
    "resend": "^6.14.0",
    "rxjs": "7.8.1",
    "swagger-ui-express": "5.0.1",
    "typeorm": "0.3.21",
    "winston": "3.17.0"
  },
  "devDependencies": {
    "@nestjs/cli": "10.0.0",
    "@nestjs/schematics": "10.0.0",
    "@nestjs/testing": "10.0.0",
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "4.17.17",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.9",
    "@types/morgan": "1.9.9",
    "@types/node": "20.17.23",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.0",
    "@typescript-eslint/eslint-plugin": "6.0.0",
    "@typescript-eslint/parser": "6.0.0",
    "eslint": "8.42.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "jest": "29.7.0",
    "prettier": "3.0.0",
    "source-map-support": "0.5.21",
    "supertest": "6.3.3",
    "ts-jest": "29.1.0",
    "ts-loader": "9.4.3",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3"
  }
}