{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "outputs": [
        "dist/**"
      ],
      "outputLogs": "new-only",
      "env": [
        "VITE_API_URL",
        "VITE_FIREBASE_API_KEY",
        "VITE_FIREBASE_PROJECT_ID",
        "VITE_GOOGLE_CLIENT_ID",
        "VITE_GOOGLE_WEB_CLIENT_ID",
        "VITE_IS_MOBILE_BUILD"
      ]
    },
    "mobile:build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "android/app/build/outputs/**"
      ],
      "outputLogs": "new-only"
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ]
    },
    "test:e2e": {
      "dependsOn": [
        "^test:e2e"
      ]
    },
    "test:cov": {
      "dependsOn": [
        "^test:cov"
      ]
    }
  }
}